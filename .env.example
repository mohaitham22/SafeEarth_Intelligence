# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: postgresql+asyncpg://postgres:postgres@localhost:5432/safeearth
# Production: Neon.tech connection string
DATABASE_URL=<fill_me>

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<fill_me>
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email — Account Verification (Gmail SMTP) ─────────────────────────────────
# Used for verification emails on sign-up. If SMTP_USER or SMTP_PASSWORD is blank,
# the app degrades to a dev log (.email_dev.log) instead of sending — verification
# emails will NOT actually arrive until both are filled.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your@gmail.com>
# 16-char Gmail App Password (Google Account → Security → 2-Step → App passwords),
# NOT your regular Gmail password.
SMTP_PASSWORD=<16_char_app_password>

# ── Email — Premium Alerts (Resend.com) ───────────────────────────────────────
# Used for Premium-tier disaster alert emails. Blank RESEND_API_KEY → dev log only.
RESEND_API_KEY=<fill_me>
# RESEND_FROM_EMAIL's domain MUST be verified in the Resend dashboard or sends fail.
RESEND_FROM_EMAIL=alerts@safeearth.tech

# Email send robustness (optional — sensible defaults baked in)
EMAIL_TIMEOUT_SECONDS=15
EMAIL_MAX_RETRIES=3

# ── ML Models (Hugging Face Hub) ──────────────────────────────────────────────
# Read-only token from huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=<fill_me>
HUGGINGFACE_REPO_ID=<fill_me>

# ── RAG (Groq) ────────────────────────────────────────────────────────────────
GROQ_API_KEY=<fill_me>

# ── Automation (n8n) ──────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=<fill_me>
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ALERT_DISPATCH_SECRET=<fill_me>

# ── Payment ───────────────────────────────────────────────────────────────────
# Values: mock | stripe | paymob
PAYMENT_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=<fill_me>

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_GUEST=10
RATE_LIMIT_AUTH=60

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Also set these in the Vercel dashboard for production
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXTAUTH_SECRET=<fill_me>
NEXTAUTH_URL=http://localhost:3000
